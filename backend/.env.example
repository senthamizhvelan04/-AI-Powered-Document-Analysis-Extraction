# Document Analysis API - Environment Variables
# Copy this file to .env and fill in your actual values

# Secret key for x-api-key header authentication
API_KEY=

# Google Gemini API key for AI analysis
GEMINI_API_KEY=

# Redis connection string for Celery async processing (optional - has sync fallback)
REDIS_URL=redis://localhost:6379/0

# Use Google Cloud Vision API instead of Tesseract for image OCR (true/false)
GOOGLE_CLOUD_VISION=false
